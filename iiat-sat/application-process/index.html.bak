  <script>
    (function () {
      const root = document.documentElement;
      root.classList.remove('dark');
      localStorage.setItem('theme', 'light');
      root.style.setProperty('--primary', '#e34614');
    })();
  </script>
  <style>
    :root { --primary:#e34614;--primary-dark:#cc5227;--wheat-light:#fedfb9;--wheat-lighter:#fef6e8; }
    html { color-scheme:light !important; }
    body { background:#fedfb9 !important; color:#3b2314 !important; }
    h1,h2,h3,h4,h5,h6 { color:#2d1a0e !important; }
    .bg-background { background:#fedfb9 !important; }
    header nav > div { background:rgba(254,246,232,0.9) !important; border-color:#e8d5b5 !important; box-shadow:0 1px 3px rgba(45,26,14,0.08) !important; backdrop-filter:blur(20px) !important; }
    header nav ul a .leading-none, header nav ul div .leading-none, header nav ul button .leading-none { color:#3b2314 !important; }
    header nav ul a:hover .leading-none { color:#e34614 !important; }
    .lucide-menu { stroke:#3b2314 !important; }
    
    .bg-primary *, .bg-primary { color:#fff !important; }
    footer, footer > div { background:#f7e8ca !important; border-color:#e8d5b5 !important; }
    footer a { color:#7a6352 !important; } footer a:hover { color:#e34614 !important; }
    footer h3, footer h4 { color:#2d1a0e !important; }
    footer p, footer span { color:#5c4033 !important; }
    ::-webkit-scrollbar { width:6px; } ::-webkit-scrollbar-track { background:#f7e8ca; }
    ::-webkit-scrollbar-thumb { background:#da8159; border-radius:3px; }
    ::selection { background:rgba(227,70,20,0.2); color:#2d1a0e; }

    .hero-section { position:relative; padding:8rem 1.5rem 3rem; text-align:center; }
    .hero-badge { display:inline-flex; align-items:center; gap:0.5rem; padding:0.375rem 1rem; border-radius:9999px; font-size:0.8rem; font-weight:600; background:rgba(227,70,20,0.08); color:#7a2f16; border:1px solid rgba(227,70,20,0.2); margin-bottom:1.5rem; }
    .hero-badge .dot { width:6px; height:6px; border-radius:50%; background:#e34614; }
    .hero-icon { width:80px; height:80px; border-radius:1.25rem; margin:0 auto 1.5rem; display:flex; align-items:center; justify-content:center; background:linear-gradient(135deg,#e34614,#cc5227); box-shadow:0 8px 30px rgba(227,70,20,0.2); }
    .btn-submit { display:inline-flex;align-items:center;justify-content:center;gap:0.5rem; padding:0.875rem 2rem; background:linear-gradient(135deg,#e34614,#cc5227); color:#fff !important; font-weight:700; font-size:1rem; border:none; border-radius:0.75rem; cursor:pointer; transition:all 0.2s; text-decoration:none; }
    .btn-submit:hover { background:linear-gradient(135deg,#cc5227,#da8159); box-shadow:0 8px 25px rgba(227,70,20,0.3); transform:translateY(-1px); }

    /* Timeline */
    .timeline { position:relative; max-width:700px; margin:0 auto; padding-left:2.5rem; }
    .timeline::before { content:''; position:absolute; left:1rem; top:0; bottom:0; width:3px; background:linear-gradient(180deg,#e34614 0%,#da8159 50%,#e8d5b5 100%); border-radius:2px; }
    .tl-step { position:relative; margin-bottom:2.5rem; }
    .tl-step:last-child { margin-bottom:0; }
    .tl-dot { position:absolute; left:-1.75rem; top:0.25rem; width:28px; height:28px; border-radius:50%; display:flex; align-items:center; justify-content:center; font-size:0.75rem; font-weight:800; color:#fff; background:linear-gradient(135deg,#e34614,#cc5227); box-shadow:0 3px 10px rgba(227,70,20,0.25); z-index:1; }
    .tl-step.completed .tl-dot { background:linear-gradient(135deg,#059669,#10b981); }
    .tl-card { padding:1.5rem; border-radius:1rem; background:rgba(254,246,232,0.95); border:1px solid #e8d5b5; transition:border-color 0.2s; }
    .tl-card:hover { border-color:rgba(227,70,20,0.3); }
    .tl-title { font-size:1.1rem; font-weight:800; color:#2d1a0e; margin-bottom:0.375rem; }
    .tl-sub { font-size:0.8rem; font-weight:600; color:#e34614; margin-bottom:0.75rem; }
    .tl-desc { font-size:0.875rem; color:#5c4033; line-height:1.6; }
    .tl-desc ul { list-style:none; padding:0; margin:0.5rem 0 0; }
    .tl-desc li { position:relative; padding:0.25rem 0 0.25rem 1.25rem; }
    .tl-desc li::before { content:''; position:absolute; left:0; top:0.65rem; width:6px; height:6px; border-radius:50%; background:#da8159; }

    /* Info cards */
    .info-grid { display:grid; grid-template-columns:repeat(auto-fit,minmax(200px,1fr)); gap:1rem; max-width:700px; margin:2rem auto; }
    .info-card { padding:1.25rem; border-radius:1rem; background:#fef6e8; border:1px solid #e8d5b5; text-align:center; }
    .info-card .ic-val { font-size:1.25rem; font-weight:800; color:#2d1a0e; }
    .info-card .ic-lbl { font-size:0.78rem; color:#5c4033; margin-top:0.25rem; }

    /* Eligibility */
    .elig-section { max-width:700px; margin:3rem auto 0; }
    .elig-card { padding:1.5rem; border-radius:1rem; background:rgba(254,246,232,0.95); border:1px solid #e8d5b5; }
    .elig-title { font-size:1.05rem; font-weight:800; color:#2d1a0e; margin-bottom:1rem; display:flex; align-items:center; gap:0.5rem; }
    .elig-list { list-style:none; padding:0; margin:0; }
    .elig-list li { position:relative; padding:0.5rem 0 0.5rem 2rem; font-size:0.9rem; color:#3b2314; border-bottom:1px solid #e8d5b5; }
    .elig-list li:last-child { border-bottom:none; }
    .elig-list li::before { content:''; position:absolute; left:0; top:0.85rem; width:8px; height:8px; border-radius:50%; border:2px solid #e34614; }
    .elig-list li.check::before { background:#e34614; }

    /* Documents */
    .doc-grid { display:grid; grid-template-columns:repeat(auto-fit,minmax(180px,1fr)); gap:1rem; max-width:700px; margin:2rem auto 0; }
    .doc-card { padding:1rem 1.25rem; border-radius:0.75rem; background:#fef6e8; border:1px solid #e8d5b5; display:flex; align-items:center; gap:0.75rem; }
    .doc-icon { width:36px; height:36px; border-radius:0.5rem; display:flex; align-items:center; justify-content:center; background:rgba(227,70,20,0.08); flex-shrink:0; }
    .doc-name { font-size:0.85rem; font-weight:600; color:#2d1a0e; }
    .doc-note { font-size:0.72rem; color:#7a6352; margin-top:0.125rem; }

    /* Dates table */
    .dates-table { width:100%; max-width:700px; margin:2rem auto 0; border-collapse:separate; border-spacing:0; border-radius:1rem; overflow:hidden; border:1px solid #e8d5b5; background:rgba(254,246,232,0.95); }
    .dates-table th { padding:0.875rem 1.25rem; background:linear-gradient(135deg,#e34614,#cc5227); color:#fff !important; font-size:0.85rem; font-weight:700; text-align:left; }
    .dates-table td { padding:0.75rem 1.25rem; font-size:0.875rem; color:#3b2314; border-top:1px solid #e8d5b5; }
    .dates-table tr:hover td { background:rgba(227,70,20,0.02); }
    .dates-table .status-open { color:#059669; font-weight:700; }
    .dates-table .status-upcoming { color:#d97706; font-weight:600; }
    .dates-table .status-closed { color:#dc2626; font-weight:700; }

    /* FAQ */
    .faq-item { border:1px solid #e8d5b5; border-radius:1rem; margin-bottom:0.75rem; overflow:hidden; background:rgba(254,246,232,0.95); }
    .faq-btn { width:100%; display:flex; align-items:center; justify-content:space-between; padding:1rem 1.25rem; cursor:pointer; background:none; border:none; text-align:left; }
    .faq-btn:hover { background:rgba(227,70,20,0.02); }
    .faq-q { font-size:0.95rem; font-weight:700; color:#2d1a0e; }
    .faq-chev { width:20px; height:20px; transition:transform 0.3s; flex-shrink:0; }
    .faq-chev.open { transform:rotate(180deg); }
    .faq-body { max-height:0; overflow:hidden; transition:max-height 0.4s ease, padding 0.3s ease; padding:0 1.25rem; }
    .faq-body.open { max-height:600px; padding:0 1.25rem 1.25rem; }
    .faq-body p { font-size:0.875rem; color:#5c4033; line-height:1.6; }

    .translate-x-full { --tw-translate-x:100%; translate:var(--tw-translate-x) var(--tw-translate-y); }
  </style>
</head>
