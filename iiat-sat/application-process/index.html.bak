      <!-- Scholarship Tiers -->
      <div style="max-width:700px;margin:3rem auto 0;">
        <h2 class="text-2xl sm:text-3xl font-black text-center mb-2" style="color:#2d1a0e !important;">Scholarship Slabs</h2>
        <p class="text-center text-sm mb-6" style="color:#5c4033;">Higher your score, bigger your scholarship</p>
        <table class="dates-table">
          <thead>
