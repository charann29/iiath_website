      <a href="/apply/" class="block w-full text-center py-3 px-6 rounded-full bg-primary text-white font-semibold text-base hover:bg-primary/90 transition-colors">Apply Now</a>
    </div>
  </div>

  <main class="pt-20 sm:pt-24 lg:pt-28">
    <!-- Hero -->
    <section class="hero-section">
      <div class="hero-badge"><span class="dot"></span> IIAT Scholarship Assessment Test</div>
      <div class="hero-icon">
        <svg xmlns="http://www.w3.org/2000/svg" width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8Z"/><path d="M14 2v6h6"/><path d="M16 13H8"/><path d="M16 17H8"/><path d="M10 9H8"/></svg>
      </div>
      <h1 class="text-3xl sm:text-4xl lg:text-5xl font-black leading-tight" style="color:#2d1a0e !important;">
        Application <span style="color:#e34614;">Process</span>
      </h1>
      <p class="mt-4 text-base sm:text-lg max-w-2xl mx-auto" style="color:#5c4033;">
        Everything you need to know about applying for the IIAT SAT &mdash; from eligibility to registration, exam day, and results.
      </p>
      <div class="info-grid">
        <div class="info-card">
          <div class="ic-val">Free</div>
          <div class="ic-lbl">Registration</div>
        </div>
        <div class="info-card">
          <div class="ic-val">Online</div>
          <div class="ic-lbl">Exam Mode</div>
        </div>
        <div class="info-card">
          <div class="ic-val">Up to 100%</div>
          <div class="ic-lbl">Scholarship</div>
        </div>
        <div class="info-card">
          <div class="ic-val">6 Branches</div>
          <div class="ic-lbl">B.Tech CSE</div>
        </div>
      </div>
    </section>

    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 pb-16 sm:pb-20">

      <!-- Step-by-Step Timeline -->
      <h2 class="text-2xl sm:text-3xl font-black text-center mb-2" style="color:#2d1a0e !important;">How to Apply</h2>
      <p class="text-center text-sm mb-10" style="color:#5c4033;">Follow these 6 simple steps to complete your IIAT SAT application</p>

      <div class="timeline">
        <!-- Step 1 -->
        <div class="tl-step">
          <div class="tl-dot">1</div>
          <div class="tl-card">
            <div class="tl-title">Check Eligibility</div>
            <div class="tl-sub">Before you begin</div>
            <div class="tl-desc">
              Confirm you meet the basic eligibility requirements before starting the application:
              <ul>
                <li>Must have passed or be appearing for Class 12 (10+2) from a recognised board</li>
                <li>Minimum 60% aggregate in PCM (Physics, Chemistry, Mathematics) or equivalent</li>
                <li>No age restriction &mdash; open to all eligible students</li>
                <li>Both Indian nationals and NRI students can apply</li>
              </ul>
            </div>
          </div>
        </div>

        <!-- Step 2 -->
        <div class="tl-step">
          <div class="tl-dot">2</div>
          <div class="tl-card">
            <div class="tl-title">Register Online</div>
            <div class="tl-sub">5 minutes to complete</div>
            <div class="tl-desc">
              Fill out the IIAT SAT registration form with your basic details:
              <ul>
                <li>Full name, email address, and phone number</li>
                <li>City and state of residence</li>
                <li>Preferred B.Tech CSE branch</li>
                <li>10th and 12th board details with approximate percentage</li>
              </ul>
              <div style="margin-top:0.75rem;">
                <a href="/apply/" class="btn-submit" style="font-size:0.85rem;padding:0.625rem 1.5rem;">Register Now &rarr;</a>
              </div>
            </div>
          </div>
        </div>

        <!-- Step 3 -->
        <div class="tl-step">
          <div class="tl-dot">3</div>
          <div class="tl-card">
            <div class="tl-title">Receive Confirmation</div>
            <div class="tl-sub">Within 24 hours</div>
            <div class="tl-desc">
              After registration, you'll receive:
              <ul>
                <li>Email confirmation with your unique IIAT SAT application ID</li>
                <li>Exam date and time slot details</li>
                <li>Preparation resources and syllabus link</li>
                <li>WhatsApp group invitation for exam updates</li>
              </ul>
            </div>
          </div>
        </div>

        <!-- Step 4 -->
        <div class="tl-step">
          <div class="tl-dot">4</div>
          <div class="tl-card">
            <div class="tl-title">Prepare for the Exam</div>
            <div class="tl-sub">Use our free tools</div>
            <div class="tl-desc">
              Make the most of IIAT's preparation ecosystem:
              <ul>
                <li><a href="/iiat-sat/syllabus/" style="color:#e34614;font-weight:600;text-decoration:underline;">View complete syllabus</a> &mdash; 4 subjects, topic-wise weightage</li>
                <li><a href="/iiat-sat/mock-test/" style="color:#e34614;font-weight:600;text-decoration:underline;">Take a mock test</a> &mdash; 25 MCQs, 30-minute timed practice</li>
                <li><a href="/iiat-sat/branch-finder/" style="color:#e34614;font-weight:600;text-decoration:underline;">Find your ideal branch</a> &mdash; 6-question aptitude quiz</li>
                <li>Study NCERT Class 11 &amp; 12 for Maths and Physics fundamentals</li>
              </ul>
            </div>
          </div>
        </div>

        <!-- Step 5 -->
        <div class="tl-step">
          <div class="tl-dot">5</div>
          <div class="tl-card">
            <div class="tl-title">Take the IIAT SAT</div>
            <div class="tl-sub">Exam day</div>
            <div class="tl-desc">
              The online exam is proctored and lasts 60 minutes:
              <ul>
                <li>50 MCQ questions across Mathematics, Physics, Logical Reasoning, and English</li>
                <li>+4 marks for correct answer, &minus;1 for incorrect</li>
                <li>Maximum score: 200 marks</li>
                <li>Stable internet connection and webcam required</li>
                <li>Valid government ID (Aadhaar/PAN/Passport) must be kept handy</li>
              </ul>
            </div>
          </div>
        </div>

        <!-- Step 6 -->
        <div class="tl-step">
          <div class="tl-dot">6</div>
          <div class="tl-card">
            <div class="tl-title">Results &amp; Admission</div>
            <div class="tl-sub">Within 7 days of exam</div>
            <div class="tl-desc">
              After the exam, here's what happens:
              <ul>
                <li>Results declared within 7 working days via email and SMS</li>
                <li>Scholarship percentage awarded based on your IIAT SAT score</li>
                <li>Top scorers receive up to 100% tuition fee scholarship</li>
                <li>Counselling session to finalise branch and confirm admission</li>
                <li>Document verification and fee payment to secure your seat</li>
              </ul>
            </div>
          </div>
        </div>
      </div>

      <!-- Eligibility -->
      <div class="elig-section">
        <h2 class="text-2xl sm:text-3xl font-black text-center mb-2" style="color:#2d1a0e !important;">Eligibility Criteria</h2>
        <p class="text-center text-sm mb-6" style="color:#5c4033;">Who can take the IIAT SAT?</p>
        <div class="elig-card">
          <div class="elig-title">
            <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#e34614" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
            Eligible Candidates
          </div>
          <ul class="elig-list">
            <li class="check">Passed Class 12 (10+2) or appearing in current academic year</li>
            <li class="check">Minimum 60% aggregate in PCM subjects (relaxed for reserved categories)</li>
            <li class="check">Students from CBSE, ICSE, State Boards, IB, and other recognised boards</li>
            <li class="check">Diploma holders in Engineering (for lateral entry pathway)</li>
            <li class="check">No upper age limit &mdash; gap-year students welcome</li>
            <li class="check">Indian nationals and NRI/OCI candidates both eligible</li>
          </ul>
        </div>
      </div>

      <!-- Documents Required -->
      <div style="max-width:700px;margin:3rem auto 0;">
        <h2 class="text-2xl sm:text-3xl font-black text-center mb-2" style="color:#2d1a0e !important;">Documents Required</h2>
        <p class="text-center text-sm mb-6" style="color:#5c4033;">Keep these ready for registration and admission</p>
        <div class="doc-grid">
          <div class="doc-card">
            <div class="doc-icon">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#e34614" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="18" x="3" y="4" rx="2" ry="2"/><line x1="16" x2="16" y1="2" y2="6"/><line x1="8" x2="8" y1="2" y2="6"/><line x1="3" x2="21" y1="10" y2="10"/></svg>
            </div>
            <div>
              <div class="doc-name">Class 10 Marksheet</div>
              <div class="doc-note">Board exam result</div>
            </div>
          </div>
          <div class="doc-card">
            <div class="doc-icon">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#e34614" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="18" x="3" y="4" rx="2" ry="2"/><line x1="16" x2="16" y1="2" y2="6"/><line x1="8" x2="8" y1="2" y2="6"/><line x1="3" x2="21" y1="10" y2="10"/></svg>
            </div>
            <div>
              <div class="doc-name">Class 12 Marksheet</div>
              <div class="doc-note">Or appearing certificate</div>
            </div>
          </div>
          <div class="doc-card">
            <div class="doc-icon">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#e34614" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="14" x="2" y="5" rx="2"/><line x1="2" x2="22" y1="10" y2="10"/></svg>
            </div>
            <div>
              <div class="doc-name">Photo ID</div>
              <div class="doc-note">Aadhaar / PAN / Passport</div>
            </div>
          </div>
          <div class="doc-card">
            <div class="doc-icon">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#e34614" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="8" r="5"/><path d="M20 21a8 8 0 0 0-16 0"/></svg>
            </div>
            <div>
              <div class="doc-name">Passport Photo</div>
              <div class="doc-note">Recent, white background</div>
            </div>
          </div>
          <div class="doc-card">
            <div class="doc-icon">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#e34614" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14.5 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7.5L14.5 2z"/><polyline points="14 2 14 8 20 8"/></svg>
            </div>
            <div>
              <div class="doc-name">Transfer Certificate</div>
              <div class="doc-note">From last institution</div>
            </div>
          </div>
          <div class="doc-card">
            <div class="doc-icon">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#e34614" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 15s1-1 4-1 5 2 8 2 4-1 4-1V3s-1 1-4 1-5-2-8-2-4 1-4 1z"/><line x1="4" x2="4" y1="22" y2="15"/></svg>
            </div>
            <div>
              <div class="doc-name">Category Certificate</div>
              <div class="doc-note">If applicable (SC/ST/OBC)</div>
            </div>
          </div>
        </div>
      </div>

      <!-- Important Dates -->
      <div style="max-width:700px;margin:3rem auto 0;">
        <h2 class="text-2xl sm:text-3xl font-black text-center mb-2" style="color:#2d1a0e !important;">Important Dates</h2>
        <p class="text-center text-sm mb-6" style="color:#5c4033;">IIAT SAT 2026 schedule</p>
        <table class="dates-table">
          <thead>
            <tr>
              <th>Event</th>
              <th>Date</th>
              <th>Status</th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <td>Registration Opens</td>
              <td>1 January 2026</td>
              <td class="status-open">Open</td>
            </tr>
            <tr>
              <td>Early Bird Deadline</td>
              <td>15 March 2026</td>
              <td class="status-closed" style="background:rgba(220,38,38,0.12);color:#dc2626;border-color:rgba(220,38,38,0.2);">Closed</td>
            </tr>
            <tr>
              <td>Registration Closes</td>
