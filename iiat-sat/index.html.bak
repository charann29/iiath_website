  <script>
  (function(){
    // Mobile menu
    var btn=document.getElementById('mobile-menu-btn'),panel=document.getElementById('mobile-menu-panel'),overlay=document.getElementById('mobile-menu-overlay'),closeBtn=document.getElementById('mobile-menu-close');
if(btn&&panel){
  btn.addEventListener('click',function(){if(overlay)overlay.classList.remove('hidden');panel.classList.remove('translate-x-full');document.body.style.overflow='hidden';});
  function cl(){panel.classList.add('translate-x-full');if(overlay)overlay.classList.add('hidden');document.body.style.overflow='';}
  if(closeBtn)closeBtn.addEventListener('click',cl);
  if(overlay)overlay.addEventListener('click',cl);
  panel.querySelectorAll('a').forEach(function(a){a.addEventListener('click',cl);});
}
  })();
  </script>
