  <script>
    (function () {
      const root = document.documentElement;
      root.classList.remove('dark');
      localStorage.setItem('theme', 'light');
      root.style.setProperty('--primary', '#e34614');
    })();
  </script>
  <style>
    :root { --primary:#e34614;--primary-dark:#cc5227;--wheat-light:#fedfb9;--wheat-lighter:#fef6e8; }
    html { color-scheme:light !important; }
    body { background:#fedfb9 !important; color:#3b2314 !important; }
    h1,h2,h3,h4,h5,h6 { color:#2d1a0e !important; }
    .bg-background { background:#fedfb9 !important; }
    header nav > div { background:rgba(254,246,232,0.9) !important; border-color:#e8d5b5 !important; box-shadow:0 1px 3px rgba(45,26,14,0.08) !important; backdrop-filter:blur(20px) !important; }
    header nav ul a .leading-none, header nav ul div .leading-none, header nav ul button .leading-none { color:#3b2314 !important; }
    header nav ul a:hover .leading-none { color:#e34614 !important; }
    .lucide-menu { stroke:#3b2314 !important; }
    
    .bg-primary *, .bg-primary { color:#fff !important; }
    footer, footer > div { background:#f7e8ca !important; border-color:#e8d5b5 !important; }
    footer a { color:#7a6352 !important; } footer a:hover { color:#e34614 !important; }
    footer h3, footer h4 { color:#2d1a0e !important; }
    footer p, footer span { color:#5c4033 !important; }
    ::-webkit-scrollbar { width:6px; } ::-webkit-scrollbar-track { background:#f7e8ca; }
    ::-webkit-scrollbar-thumb { background:#da8159; border-radius:3px; }
    ::selection { background:rgba(227,70,20,0.2); color:#2d1a0e; }

    .hero-section { position:relative; padding:8rem 1.5rem 4rem; text-align:center; }
    .hero-badge { display:inline-flex; align-items:center; gap:0.5rem; padding:0.375rem 1rem; border-radius:9999px; font-size:0.8rem; font-weight:600; background:rgba(227,70,20,0.08); color:#7a2f16; border:1px solid rgba(227,70,20,0.2); margin-bottom:1.5rem; }
    .hero-badge .dot { width:6px; height:6px; border-radius:50%; background:#e34614; animation:pulse 2s infinite; }
    @keyframes pulse { 0%,100%{opacity:1;} 50%{opacity:0.4;} }
    .hero-icon { width:96px; height:96px; border-radius:1.5rem; margin:0 auto 2rem; display:flex; align-items:center; justify-content:center; background:linear-gradient(135deg,#e34614,#cc5227); box-shadow:0 12px 40px rgba(227,70,20,0.25); }
    .btn-primary { display:inline-flex;align-items:center;justify-content:center;gap:0.5rem; padding:0.875rem 2rem; background:linear-gradient(135deg,#e34614,#cc5227); color:#fff !important; font-weight:700; font-size:1rem; border:none; border-radius:0.75rem; cursor:pointer; transition:all 0.2s; text-decoration:none; }
    .btn-primary:hover { background:linear-gradient(135deg,#cc5227,#da8159); box-shadow:0 8px 25px rgba(227,70,20,0.3); transform:translateY(-1px); }
    .btn-secondary { display:inline-flex;align-items:center;justify-content:center;gap:0.5rem; padding:0.875rem 2rem; background:#fff; color:#2d1a0e !important; font-weight:700; font-size:1rem; border:2px solid #e8d5b5; border-radius:0.75rem; cursor:pointer; transition:all 0.2s; text-decoration:none; }
    .btn-secondary:hover { border-color:#e34614; color:#e34614 !important; box-shadow:0 4px 15px rgba(227,70,20,0.1); }

    /* Stats bar */
    .stats-bar { display:flex; flex-wrap:wrap; justify-content:center; gap:2rem; margin-top:3rem; padding:1.5rem; border-radius:1rem; background:rgba(254,246,232,0.95); border:1px solid #e8d5b5; }
    .stat-item { text-align:center; min-width:100px; }
    .stat-val { font-size:1.5rem; font-weight:900; color:#e34614; }
    .stat-lbl { font-size:0.78rem; color:#5c4033; margin-top:0.125rem; }

    /* Tool cards grid */
    .tools-grid { display:grid; grid-template-columns:repeat(auto-fit,minmax(300px,1fr)); gap:1.5rem; max-width:1000px; margin:0 auto; }
    @media (max-width:639px) { .tools-grid { grid-template-columns:1fr; } }
    .tool-card { position:relative; padding:2rem; border-radius:1.25rem; background:rgba(254,246,232,0.95); border:1px solid #e8d5b5; transition:all 0.3s; text-decoration:none; display:block; overflow:hidden; }
    .tool-card:hover { border-color:#e34614; box-shadow:0 12px 40px rgba(227,70,20,0.12); transform:translateY(-4px); }
    .tool-card::after { content:''; position:absolute; top:0; left:0; right:0; height:4px; background:linear-gradient(90deg,var(--card-color,#e34614),transparent); opacity:0; transition:opacity 0.3s; }
    .tool-card:hover::after { opacity:1; }
    .tc-icon { width:56px; height:56px; border-radius:1rem; display:flex; align-items:center; justify-content:center; margin-bottom:1.25rem; }
    .tc-title { font-size:1.15rem; font-weight:800; color:#2d1a0e; margin-bottom:0.375rem; }
    .tc-desc { font-size:0.875rem; color:#5c4033; line-height:1.6; margin-bottom:1rem; }
    .tc-cta { font-size:0.85rem; font-weight:700; color:#e34614; display:inline-flex; align-items:center; gap:0.375rem; }
    .tc-cta svg { transition:transform 0.2s; }
    .tool-card:hover .tc-cta svg { transform:translateX(4px); }
    .tc-badge { position:absolute; top:1rem; right:1rem; font-size:0.7rem; font-weight:700; padding:0.2rem 0.6rem; border-radius:0.5rem; }

    /* How it works */
    .hiw-grid { display:grid; grid-template-columns:repeat(auto-fit,minmax(180px,1fr)); gap:1.25rem; max-width:800px; margin:2rem auto 0; }
    .hiw-card { padding:1.5rem 1.25rem; border-radius:1rem; background:#fef6e8; border:1px solid #e8d5b5; text-align:center; position:relative; }
    .hiw-num { width:36px; height:36px; border-radius:50%; background:linear-gradient(135deg,#e34614,#cc5227); color:#fff !important; font-size:0.85rem; font-weight:800; display:flex; align-items:center; justify-content:center; margin:0 auto 1rem; }
    .hiw-title { font-size:0.95rem; font-weight:700; color:#2d1a0e; margin-bottom:0.25rem; }
    .hiw-desc { font-size:0.8rem; color:#5c4033; line-height:1.5; }

    /* Branches */
    .branch-grid { display:grid; grid-template-columns:repeat(auto-fit,minmax(270px,1fr)); gap:1rem; max-width:1000px; margin:2rem auto 0; }
    .branch-chip { padding:1rem 1.25rem; border-radius:0.75rem; background:#fef6e8; border:1px solid #e8d5b5; display:flex; align-items:center; justify-content:space-between; gap:1rem; transition:border-color 0.2s; }
    .branch-chip:hover { border-color:rgba(227,70,20,0.3); }
    .branch-name { font-size:0.9rem; font-weight:700; color:#2d1a0e; }
    .branch-seats { font-size:0.75rem; font-weight:600; color:#e34614; background:rgba(227,70,20,0.08); padding:0.2rem 0.6rem; border-radius:0.375rem; white-space:nowrap; }

    .translate-x-full { --tw-translate-x:100%; translate:var(--tw-translate-x) var(--tw-translate-y); }
  </style>
