      </div>
      <h1 class="text-3xl sm:text-4xl lg:text-5xl font-black leading-tight" style="color:#2d1a0e !important;">
        IIAT Scholarship<br><span style="color:#e34614;">Assessment Test</span>
      </h1>
      <p class="mt-4 text-base sm:text-lg max-w-2xl mx-auto" style="color:#5c4033;">
        Your gateway to a world-class B.Tech CSE education with scholarships up to 100%. Free registration, online exam, and instant scholarship allocation based on your score.
      </p>
      <div style="display:flex;flex-wrap:wrap;gap:0.75rem;justify-content:center;margin-top:2rem;">
        <a href="/apply/" class="btn-primary">Register Free &rarr;</a>
        <a href="/iiat-sat/mock-test/" class="btn-secondary">Try Mock Test</a>
      </div>

      <div class="stats-bar" style="max-width:700px;margin:3rem auto 0;">
        <div class="stat-item">
          <div class="stat-val">Free</div>
          <div class="stat-lbl">Registration</div>
        </div>
        <div class="stat-item">
          <div class="stat-val">50</div>
          <div class="stat-lbl">MCQ Questions</div>
        </div>
        <div class="stat-item">
          <div class="stat-val">60 min</div>
          <div class="stat-lbl">Duration</div>
        </div>
        <div class="stat-item">
          <div class="stat-val">100%</div>
          <div class="stat-lbl">Max Scholarship</div>
        </div>
        <div class="stat-item">
          <div class="stat-val">720</div>
          <div class="stat-lbl">Total Seats</div>
        </div>
      </div>
    </section>

    <!-- Tools Section -->
    <section class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 pb-16">
      <h2 class="text-2xl sm:text-3xl font-black text-center mb-2" style="color:#2d1a0e !important;">IIAT SAT Tools</h2>
      <p class="text-center text-sm mb-10" style="color:#5c4033;">Everything you need to prepare, predict, and apply</p>

      <div class="tools-grid">
        <!-- Mock Test -->
        <a href="/iiat-sat/mock-test/" class="tool-card" style="--card-color:#3b82f6;">
          <span class="tc-badge" style="background:rgba(59,130,246,0.1);color:#2563eb;">Practice</span>
          <div class="tc-icon" style="background:rgba(59,130,246,0.1);">
            <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#2563eb" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
          </div>
          <div class="tc-title">Mock Test</div>
          <div class="tc-desc">25 MCQs across 4 subjects with a 30-minute timer. Simulate the real exam experience with instant scoring and detailed review.</div>
          <span class="tc-cta">Start Practice <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg></span>
        </a>

        <!-- Syllabus -->
        <a href="/iiat-sat/syllabus/" class="tool-card" style="--card-color:#8b5cf6;">
          <span class="tc-badge" style="background:rgba(139,92,246,0.1);color:#7c3aed;">Study</span>
          <div class="tc-icon" style="background:rgba(139,92,246,0.1);">
            <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#7c3aed" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 19.5v-15A2.5 2.5 0 0 1 6.5 2H19a1 1 0 0 1 1 1v18a1 1 0 0 1-1 1H6.5a1 1 0 0 1 0-5H20"/></svg>
          </div>
          <div class="tc-title">Complete Syllabus</div>
          <div class="tc-desc">Topic-by-topic breakdown for Maths, Physics, Logical Reasoning, and English with weightage badges and preparation tips.</div>
          <span class="tc-cta">View Syllabus <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg></span>
        </a>

        <!-- Branch Finder -->
        <a href="/iiat-sat/branch-finder/" class="tool-card" style="--card-color:#10b981;">
          <span class="tc-badge" style="background:rgba(16,185,129,0.1);color:#059669;">Discover</span>
          <div class="tc-icon" style="background:rgba(16,185,129,0.1);">
            <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#059669" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
          </div>
          <div class="tc-title">Branch Finder</div>
          <div class="tc-desc">Not sure which B.Tech CSE branch suits you? Answer 6 quick questions and get a personalised recommendation with match percentage.</div>
          <span class="tc-cta">Find My Branch <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg></span>
        </a>

        <!-- Rank Predictor -->
        <a href="/iiat-sat/rank-predictor/" class="tool-card" style="--card-color:#f59e0b;">
          <span class="tc-badge" style="background:rgba(245,158,11,0.1);color:#d97706;">Predict</span>
          <div class="tc-icon" style="background:rgba(245,158,11,0.1);">
            <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#d97706" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 3v18h18"/><path d="m19 9-5 5-4-4-3 3"/></svg>
          </div>
          <div class="tc-title">Rank Predictor</div>
          <div class="tc-desc">Enter your expected IIAT SAT score to see your predicted rank, scholarship tier, and estimated fee after discount.</div>
          <span class="tc-cta">Predict My Rank <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg></span>
        </a>

        <!-- College Predictor -->
        <a href="/iiat-sat/college-predictor/" class="tool-card" style="--card-color:#ec4899;">
          <span class="tc-badge" style="background:rgba(236,72,153,0.1);color:#db2777;">Compare</span>
          <div class="tc-icon" style="background:rgba(236,72,153,0.1);">
            <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#db2777" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 10v6M2 10l10-5 10 5-10 5z"/><path d="M6 12v5c0 1.1 2.7 3 6 3s6-1.9 6-3v-5"/></svg>
          </div>
          <div class="tc-title">College Predictor</div>
