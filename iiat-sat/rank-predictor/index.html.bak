        <div><h4 class="font-bold text-sm mb-3" style="color:#2d1a0e;">Contact</h4><div class="space-y-2 text-sm"><a href="tel:+918688664337" class="block" style="color:#7a6352;">+91 868 866 4337</a><a href="mailto:info@iiath.com" class="block" style="color:#7a6352;">info@iiath.com</a><p style="color:#7a6352;font-size:0.8rem;line-height:1.4;margin-top:0.5rem;">Manjeera Square & OT, Plot No. 6 & 7, Flat No. 02, Sanjeev Reddy Nagar, Ameerpet, Hyderabad - 500038</p></div></div>
      </div>
      <div class="mt-8 pt-6 border-t text-center text-xs" style="border-color:#e8d5b5;color:#9a8574;"><p>&copy; 2026 Indian Institute of Advanced Technologies (IIAT). All rights reserved. InnoFutureTech Pvt. Ltd.</p></div>
    </div>
  </footer>

  <script>
    // Supabase config
    var SUPABASE_URL = 'https://diacczkzcxylmlvysqar.supabase.co';
    var SUPABASE_ANON_KEY = 'eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImRpYWNjemt6Y3h5bG1sdnlzcWFyIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzA2OTYyODQsImV4cCI6MjA4NjI3MjI4NH0.4e1ayR8Nu_laj0Ne6mSGVZTV6nLCmLHWs16ekN1n70E';

    function predictRank(e) {
      e.preventDefault();
      var score = parseInt(document.getElementById('score').value);
      var category = document.getElementById('category').value;
      var prefBranch = document.getElementById('pref-branch').value;
      if (isNaN(score) || score < 0 || score > 200) {
        document.getElementById('score').setCustomValidity('Please enter a score between 0 and 200.');
        document.getElementById('score').reportValidity();
        return;
      }
      document.getElementById('score').setCustomValidity('');

      // Deterministic rank prediction
      var totalStudents = 5000;
      var rank;
      if (score >= 190) rank = Math.max(1, Math.round((200 - score) * 1.5) + 1);
      else if (score >= 180) rank = Math.round(16 + (190 - score) * 3);
      else if (score >= 160) rank = Math.round(46 + (180 - score) * 5);
      else if (score >= 140) rank = Math.round(146 + (160 - score) * 15);
      else if (score >= 120) rank = Math.round(446 + (140 - score) * 30);
      else if (score >= 100) rank = Math.round(1046 + (120 - score) * 50);
      else if (score >= 80) rank = Math.round(2046 + (100 - score) * 60);
      else rank = Math.round(3246 + (80 - score) * 25);

      // Category adjustment (reserved categories get slight rank benefit)
      if (category === 'obc') rank = Math.max(1, Math.round(rank * 0.92));
      else if (category === 'sc') rank = Math.max(1, Math.round(rank * 0.85));
      else if (category === 'st') rank = Math.max(1, Math.round(rank * 0.82));
      else if (category === 'ews') rank = Math.max(1, Math.round(rank * 0.90));

      // Store computed values for after lead capture
      window._rankResult = { score: score, rank: rank, category: category, prefBranch: prefBranch };

      // Show lead capture modal
      document.getElementById('lead-modal-overlay').classList.add('active');
      document.body.style.overflow = 'hidden';
    }

    function displayRankResult() {
      var r = window._rankResult;
      if (!r) return;

      document.getElementById('rank-num').textContent = r.rank <= 50 ? 'Top ' + r.rank : r.rank + ' / ~5000';

      var tierHtml = '';
      if (r.score >= 180) tierHtml = '<span class="tier-badge tier-gold">Gold Scholarship (100% Tuition Waiver)</span>';
      else if (r.score >= 160) tierHtml = '<span class="tier-badge tier-silver">Silver Scholarship (75% Tuition Waiver)</span>';
      else if (r.score >= 140) tierHtml = '<span class="tier-badge tier-bronze">Bronze Scholarship (50% Tuition Waiver)</span>';
      else if (r.score >= 100) tierHtml = '<span class="tier-badge tier-eligible">Merit Scholarship Eligible</span>';
      else tierHtml = '<span class="tier-badge tier-eligible">Standard Admission</span>';
      document.getElementById('tier-badge').innerHTML = tierHtml;

      var branchKeyMap = {
        'ai-ds': 'CSE (AI & Data Science)',
        'fintech': 'CSE (FinTech & AI)',
        'core': 'CSE (Core)',
        'ai-ml': 'CSE (AI & Machine Learning)',
        'cyber': 'CSE (Cyber Security with AI/ML)',
        'biomed': 'Biomedical Eng., AI & Medical Robotics'
      };

      var branches = [
        { key: 'ai-ds', name: 'CSE (AI & Data Science)', seats: 180, cutoff: 90 },
        { key: 'ai-ml', name: 'CSE (AI & Machine Learning)', seats: 180, cutoff: 85 },
        { key: 'core', name: 'CSE (Core)', seats: 180, cutoff: 80 },
        { key: 'fintech', name: 'CSE (FinTech & AI)', seats: 60, cutoff: 100 },
        { key: 'cyber', name: 'CSE (Cyber Security with AI/ML)', seats: 60, cutoff: 95 },
        { key: 'biomed', name: 'Biomedical Eng., AI & Medical Robotics', seats: 60, cutoff: 75 }
      ];

      var html = '<p style="font-weight:700;color:#2d1a0e;margin-bottom:0.75rem;font-size:0.95rem;">Branch Eligibility</p>';
      branches.forEach(function(b) {
        var status, cls;
        if (r.score >= b.cutoff + 20) { status = 'Eligible'; cls = 'status-eligible'; }
        else if (r.score >= b.cutoff) { status = 'Borderline'; cls = 'status-borderline'; }
        else { status = 'Below Cutoff'; cls = 'status-unlikely'; }
        var isPreferred = (r.prefBranch !== 'any' && r.prefBranch === b.key);
        var prefClass = isPreferred ? ' preferred' : '';
        var prefLabel = isPreferred ? ' <span style="font-size:0.7rem;color:#e34614;font-weight:600;margin-left:0.5rem;">&#9733; YOUR PICK</span>' : '';
        html += '<div class="branch-item' + prefClass + '"><span class="name">' + b.name + prefLabel + '</span><span class="status ' + cls + '">' + status + '</span></div>';
      });
      document.getElementById('branch-list').innerHTML = html;
      document.getElementById('result-box').style.display = 'block';
      document.getElementById('result-box').scrollIntoView({behavior:'smooth'});
    }

    function hideLeadModal() {
      document.getElementById('lead-modal-overlay').classList.remove('active');
      document.body.style.overflow = '';
    }

    // Lead capture form submission
    document.getElementById('lead-capture-form').addEventListener('submit', function(e) {
      e.preventDefault();
      var submitBtn = document.getElementById('lead-submit-btn');
      var fullName = document.getElementById('lead-name').value.trim();
      var phone = document.getElementById('lead-phone').value.trim();
      var email = document.getElementById('lead-email').value.trim();
      var city = document.getElementById('lead-city').value.trim() || null;

      if (!fullName || !phone || !email) return;

      submitBtn.disabled = true;
      submitBtn.textContent = 'Processing...';

      // Only send columns that exist in Supabase leads table
      var leadData = {
        user_id: crypto.randomUUID(),
        email: email,
        name: fullName,
        phone: phone,
        source: 'iiat-sat-rank-predictor'
      };

      // Store full data in localStorage (including extra fields)
      try {
        localStorage.setItem('rank-predictor-lead', JSON.stringify(Object.assign({}, leadData, {
          city: city,
          predicted_rank: window._rankResult ? window._rankResult.rank : null
        })));
      } catch(ex) {}

      // Send to Supabase
      fetch(SUPABASE_URL + '/rest/v1/leads', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
          'apikey': SUPABASE_ANON_KEY,
          'Authorization': 'Bearer ' + SUPABASE_ANON_KEY,
          'Prefer': 'return=minimal'
        },
        body: JSON.stringify(leadData)
      }).then(function() {
        hideLeadModal();
        displayRankResult();
      }).catch(function() {
        // Always show result even if Supabase fails
        hideLeadModal();
        displayRankResult();
      });
    });

    // Mobile menu
    var btn=document.getElementById('mobile-menu-btn'),panel=document.getElementById('mobile-menu-panel'),overlay=document.getElementById('mobile-menu-overlay'),closeBtn=document.getElementById('mobile-menu-close');
if(btn&&panel){
  btn.addEventListener('click',function(){if(overlay)overlay.classList.remove('hidden');panel.classList.remove('translate-x-full');document.body.style.overflow='hidden';});
  function cl(){panel.classList.add('translate-x-full');if(overlay)overlay.classList.add('hidden');document.body.style.overflow='';}
  if(closeBtn)closeBtn.addEventListener('click',cl);
  if(overlay)overlay.addEventListener('click',cl);
  panel.querySelectorAll('a').forEach(function(a){a.addEventListener('click',cl);});
}
  </script>
</body>
</html>
