  <main class="pt-20 sm:pt-24 lg:pt-28">
    <section class="hero-section">
      <div class="hero-badge"><span class="dot"></span> IIAT Scholarship Assessment Test</div>
      <div class="hero-icon">
        <svg xmlns="http://www.w3.org/2000/svg" width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 12h-2.48a2 2 0 0 0-1.93 1.46l-2.35 8.36a.25.25 0 0 1-.48 0L9.24 2.18a.25.25 0 0 0-.48 0l-2.35 8.36A2 2 0 0 1 4.49 12H2"/></svg>
      </div>
      <h1 class="text-3xl sm:text-4xl lg:text-5xl font-black leading-tight" style="color:#2d1a0e !important;">
        <span style="color:#e34614;">Rank</span> Predictor
      </h1>
      <p class="mt-4 text-base sm:text-lg max-w-2xl mx-auto" style="color:#5c4033;">
        Enter your expected IIAT SAT score to predict your rank, scholarship tier, and branch eligibility. Our predictor uses historical data and seat matrix analysis.
      </p>
      <div class="feature-grid max-w-3xl mx-auto">
        <div class="feature-card">
          <h4>Rank Estimation</h4>
          <p>Get an estimated rank range based on your score and the expected number of test-takers.</p>
        </div>
        <div class="feature-card">
          <h4>Scholarship Tiers</h4>
          <p>See which scholarship tier you qualify for: Gold (100%), Silver (75%), Bronze (50%), or Merit.</p>
        </div>
        <div class="feature-card">
          <h4>Branch Eligibility</h4>
          <p>Find out which of the 6 B.Tech specializations are open at your predicted rank.</p>
        </div>
      </div>
    </section>

    <div class="max-w-2xl mx-auto px-4 sm:px-6 lg:px-8 pb-16 sm:pb-20">
      <div class="calc-container">
        <h2 class="text-xl font-bold mb-1" style="color:#2d1a0e !important;">Predict Your Rank</h2>
        <p class="mb-6 text-sm" style="color:#5c4033;">Enter your expected score (out of 200) to get your predicted rank and scholarship eligibility.</p>
        <form id="rank-form" onsubmit="predictRank(event)" class="space-y-5">
          <div>
            <label class="form-label" for="score">Expected IIAT SAT Score (0-200) *</label>
            <input type="number" id="score" name="score" class="form-input" placeholder="e.g. 145" min="0" max="200" required>
          </div>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
            <div>
              <label class="form-label" for="category">Category</label>
              <select id="category" name="category" class="form-select">
                <option value="general">General</option>
                <option value="obc">OBC</option>
                <option value="sc">SC</option>
                <option value="st">ST</option>
                <option value="ews">EWS</option>
              </select>
            </div>
            <div>
              <label class="form-label" for="pref-branch">Preferred Branch</label>
              <select id="pref-branch" name="prefBranch" class="form-select">
                <option value="any">Any / All Branches</option>
                <option value="ai-ds">CSE (AI & Data Science)</option>
                <option value="fintech">CSE (FinTech & AI)</option>
                <option value="core">CSE (Core)</option>
                <option value="ai-ml">CSE (AI & Machine Learning)</option>
                <option value="cyber">CSE (Cyber Security with AI/ML)</option>
                <option value="biomed">Biomedical Eng., AI & Medical Robotics</option>
              </select>
            </div>
          </div>
          <button type="submit" class="btn-submit">Predict My Rank &rarr;</button>
        </form>

        <div class="result-box" id="result-box">
          <p class="rank-label">Your Predicted Rank</p>
          <div class="rank-num" id="rank-num"></div>
          <div id="tier-badge"></div>
          <div class="branch-list" id="branch-list"></div>
          <div style="margin-top:1.5rem;display:flex;flex-wrap:wrap;gap:0.75rem;justify-content:center;">
            <a href="/apply/" class="btn-submit" style="width:auto;display:inline-flex;padding:0.75rem 2rem;">Apply Now &rarr;</a>
            <a href="/iiat-sat/mock-test/" style="padding:0.75rem 2rem;border:1px solid #e8d5b5;border-radius:0.75rem;background:#fff;color:#2d1a0e;font-weight:600;text-decoration:none;display:inline-block;">Take Mock Test</a>
          </div>
        </div>
      </div>
    </div>

    <!-- Lead Capture Modal -->
    <div class="lead-modal-overlay" id="lead-modal-overlay">
      <div class="lead-modal">
        <h3>See Your Predicted Rank</h3>
        <p class="subtitle">Enter your details to unlock your rank prediction, scholarship tier, and branch eligibility.</p>
        <form id="lead-capture-form" autocomplete="on">
          <div class="lead-form-group">
            <label class="form-label" for="lead-name">Full Name <span style="color:#e34614;">*</span></label>
            <input class="form-input" type="text" id="lead-name" name="full_name" placeholder="Enter your full name" required>
          </div>
          <div class="lead-form-group">
            <label class="form-label" for="lead-phone">Phone <span style="color:#e34614;">*</span></label>
            <input class="form-input" type="tel" id="lead-phone" name="phone" placeholder="Enter your phone number" required pattern="[0-9]{10}" title="Please enter a valid 10-digit phone number" maxlength="10">
          </div>
          <div class="lead-form-group">
            <label class="form-label" for="lead-email">Email <span style="color:#e34614;">*</span></label>
            <input class="form-input" type="email" id="lead-email" name="email" placeholder="Enter your email address" required>
          </div>
          <div class="lead-form-group">
            <label class="form-label" for="lead-city">City</label>
            <input class="form-input" type="text" id="lead-city" name="city" placeholder="Enter your city (optional)">
          </div>
          <button type="submit" class="btn-submit" id="lead-submit-btn">Unlock My Rank &rarr;</button>
          <p class="privacy-note">Your information is secure and will only be used to personalize your experience. We respect your privacy.</p>
        </form>
      </div>
    </div>
  </main>

  <footer class="w-full border-t py-8 sm:py-12" style="border-color:#e8d5b5;">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-12">
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8">
        <div><img alt="IIAT logo" width="200" height="86" class="h-12 sm:h-14 w-auto max-w-[280px] object-contain mb-4" src="../../assets/new/IIAT_logo.png"><p class="text-sm" style="color:#5c4033;">Indian Institute of Advanced Technologies<br>by InnoFutureTech Private Limited</p></div>
        <div><h4 class="font-bold text-sm mb-3" style="color:#2d1a0e;">IIAT SAT Tools</h4><div class="space-y-2 text-sm"><a href="/iiat-sat/branch-finder/" class="block" style="color:#7a6352;">Branch Finder</a><a href="/iiat-sat/rank-predictor/" class="block" style="color:#e34614;font-weight:600;">Rank Predictor</a><a href="/iiat-sat/college-predictor/" class="block" style="color:#7a6352;">College Predictor</a><a href="/iiat-sat/mock-test/" class="block" style="color:#7a6352;">Mock Test</a><a href="/iiat-sat/syllabus/" class="block" style="color:#7a6352;">Syllabus</a><a href="/iiat-sat/application-process/" class="block" style="color:#7a6352;">Application Process</a></div></div>
